                  "id": "482e3006-977a-4199-82ab-3eade3c41dbe",
                  "title": "Suplantación de identidad del usuario.",
                  "status": "Open",
                  "severity": "High",
                  "type": "Spoofing / Spoofing",
                  "description": "Existe el riesgo de que un atacante suplante a un usuario legítimo mediante el robo de cookies de sesión o credenciales de acceso, permitiendo el ingreso no autorizado al sistema.",
                  "mitigation": "Implementar autenticación multifactor (MFA), forzar el uso de protocolos seguros (HTTPS/TLS) y configurar flags de seguridad en las cookies (HttpOnly, Secure, SameSite) para evitar el secuestro de sesión.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 2,
                  "score": ""
                }
              ],
              "threatFrequency": {
