                {
                  "id": "8db69e93-df69-4558-958c-33b910fb835b",
                  "title": "Escalada de privilegios en el API.",
                  "status": "Open",
                  "severity": "Critical",
                  "type": "Elevation of privilege / Elevación de privilegios",
                  "description": "Un usuario autenticado con pocos privilegios podría explotar una vulnerabilidad en los endpoints del API (por ejemplo, mediante manipulación de parámetros o IDOR - Insecure Direct Object Reference) para acceder a funciones o datos reservados únicamente a administradores.\n",
                  "mitigation": "Implementar control de acceso basado en roles (RBAC) o basado en atributos (ABAC) validado en el servidor, aplicar el principio de menor privilegio, y realizar pruebas de validación de autorización en cada petición del API.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 4,
                  "score": ""
                }
              ],
